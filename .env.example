# Copy this file to .env and fill in your values.
# .env is gitignored — never commit the real secrets.

# ── Supabase ──────────────────────────────────────────────────────
# Find all of these at: supabase.com → your project → Settings → API

# Project URL  (safe, used by both frontend and backend)
SUPABASE_URL=https://your-project-ref.supabase.co

# anon/public key  (safe, sent to browser via /config.js)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# service_role key  (SECRET — server only, never exposed to browser)
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# JWT secret  (SECRET — Settings → API → JWT Settings → JWT Secret)
SUPABASE_JWT_SECRET=your-jwt-secret-here

# ── Strava (optional) ─────────────────────────────────────────────
# Create an API app at strava.com/settings/api
# Authorization Callback Domain: your Vercel domain (localhost works automatically)

# Client ID  (safe, sent to browser via /config.js)
STRAVA_CLIENT_ID=12345

# Client secret  (SECRET — server / Vercel env vars only)
STRAVA_CLIENT_SECRET=your-strava-client-secret
